<%- include('partials/header') %>

<div class="row justify-content-center align-items-center py-5" style="min-height: 75vh;">
  <div class="col-md-6 col-lg-5">
    
    <!-- Alert Notifications -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background-color: #FEF2F2; color: #B91C1C; border-left: 4px solid #EF4444; border-radius: 8px;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background-color: #ECFDF5; color: #047857; border-left: 4px solid #10B981; border-radius: 8px;">
        <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

      <!-- Login Card -->
      <div class="card p-4 p-md-5 border-0 shadow-sm" style="border-radius: 24px; background-color: #FFFFFF;">
        
        <!-- Header -->
        <div class="text-center mb-4">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background-color: rgba(37, 99, 235, 0.08); color: #2563EB;">
            <i class="bi bi-person-circle fs-1"></i>
          </div>
          <h3 class="fw-extrabold" style="font-family: 'Outfit', sans-serif; color: #0F172A; font-size: 1.8rem; margin-bottom: 6px;">Student Login</h3>
          <p class="text-muted small" style="color: #64748B !important; font-size: 0.95rem;">Sign in to submit admission inquiries and track status</p>
        </div>

        <!-- Form -->
        <form action="/student/login" method="POST">
          <div class="mb-4">
            <label for="email" class="form-label" style="font-weight: 600; color: #334155; font-size: 0.9rem;">Email Address</label>
            <div class="input-group">
              <span class="input-group-text" style="background-color: #F8FAFC; border-color: #CBD5E1; color: #64748B;"><i class="bi bi-envelope"></i></span>
              <input type="email" class="form-control" id="email" name="email" placeholder="student@example.com" style="border-color: #CBD5E1; background-color: #FFFFFF; color: #334155;" required>
            </div>
          </div>

          <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <label for="password" class="form-label" style="font-weight: 600; color: #334155; font-size: 0.9rem; margin-bottom: 0;">Password</label>
            </div>
            <div class="input-group">
              <span class="input-group-text" style="background-color: #F8FAFC; border-color: #CBD5E1; color: #64748B;"><i class="bi bi-key"></i></span>
              <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" style="border-color: #CBD5E1; background-color: #FFFFFF; color: #334155;" required>
            </div>
          </div>

          <button type="submit" class="btn btn-primary-blue w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center gap-2" style="background-color: #2563EB; border-color: #2563EB; font-size: 1rem; border-radius: 12px; color: #ffffff;">
            <i class="bi bi-box-arrow-in-right"></i> Sign In to Account
          </button>
        </form>
        
        <div class="text-center mt-4 pt-3 border-top border-light">
          <span class="text-muted small" style="color: #64748B !important;">Don't have a student account yet?</span>
          <a href="/student/register" class="text-primary-blue text-decoration-none small fw-bold ms-1" style="color: #2563EB;">Register Here <i class="bi bi-arrow-right"></i></a>
        </div>

      </div>
    </div>
  </div>

<%- include('partials/footer') %>
