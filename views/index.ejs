            <!-- 2. Document Support -->
            <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-light d-flex align-items-center gap-3 transition-hover" style="transition: all 0.2s ease; border-radius: 12px;">
              <div class="rounded-circle bg-soft-blue d-flex align-items-center justify-content-center text-primary-blue" style="width: 48px; height: 48px; flex-shrink: 0; background-color: rgba(37, 99, 235, 0.08); color: #2563EB;">
