            <!-- 3. Application Tracking -->
            <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-light d-flex align-items-center gap-3 transition-hover" style="transition: all 0.2s ease; border-radius: 12px;">
              <div class="rounded-circle bg-soft-blue d-flex align-items-center justify-content-center text-primary-blue" style="width: 48px; height: 48px; flex-shrink: 0; background-color: rgba(37, 99, 235, 0.08); color: #2563EB;">
                <i class="bi bi-clock-history fs-5"></i>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-center justify-content-between">
                  <h6 class="fw-bold mb-0" style="color: #0F172A; font-size: 0.95rem;">Application Tracking</h6>
                  <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2 py-1" style="font-size: 0.7rem; color: #b45309 !important; background-color: rgba(245, 158, 11, 0.08) !important;">Real-time</span>
                </div>
                <p class="text-muted small mb-0" style="font-size: 0.8rem; line-height: 1.4; color: #64748B !important;">Check your admission pipeline status instantly in our workspace.</p>
              </div>
            </div>

            <!-- 4. Counsellor Follow-up -->
            <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-light d-flex align-items-center gap-3 transition-hover" style="transition: all 0.2s ease; border-radius: 12px;">
              <div class="rounded-circle bg-soft-blue d-flex align-items-center justify-content-center text-primary-blue" style="width: 48px; height: 48px; flex-shrink: 0; background-color: rgba(37, 99, 235, 0.08); color: #2563EB;">
                <i class="bi bi-telephone-outbound fs-5"></i>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-center justify-content-between">
                  <h6 class="fw-bold mb-0" style="color: #0F172A; font-size: 0.95rem;">Counsellor Follow-up</h6>
                  <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-2 py-1" style="font-size: 0.7rem; color: #0891b2 !important; background-color: rgba(6, 182, 212, 0.08) !important;">24h SLA</span>
                </div>
                <p class="text-muted small mb-0" style="font-size: 0.8rem; line-height: 1.4; color: #64748B !important;">Receive dedicated callbacks and updates regarding enrollment details.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

