                  <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1" style="font-size: 0.7rem; color: #2563EB !important; background-color: rgba(37, 99, 235, 0.08) !important;">Digital</span>
                </div>
                <p class="text-muted small mb-0" style="font-size: 0.8rem; line-height: 1.4; color: #64748B !important; ">Fast digital verification of transcripts and credentials.</p>
              </div>
