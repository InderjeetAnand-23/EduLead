          <div class="d-flex flex-column gap-3">
            <!-- 1. Admission Guidance -->
            <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-light d-flex align-items-center gap-3 transition-hover" style="transition: all 0.2s ease; border-radius: 12px;">
              <div class="rounded-circle bg-soft-blue d-flex align-items-center justify-content-center text-primary-blue" style="width: 48px; height: 48px; flex-shrink: 0; background-color: rgba(37, 99, 235, 0.08); color: #2563EB;">
                <i class="bi bi-compass fs-5"></i>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-center justify-content-between">
                  <h6 class="fw-bold mb-0" style="color: #0F172A; font-size: 0.95rem;">Admission Guidance</h6>
                  <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1" style="font-size: 0.7rem;">Free Session</span>
                </div>
