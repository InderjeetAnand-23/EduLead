<!-- Custom Micro-Interaction Script for Program Card clicks -->
<script>
  // Whether student is currently logged in (injected by server)
  const isStudentLoggedIn = <%= student ? 'true' : 'false' %>;

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.program-inquire-btn').forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const selectedProgramName = this.getAttribute('data-program');

        if (!isStudentLoggedIn) {
          // Not logged in — save destination and go to student login
          window.location.href = '/student/login';
          return;
        }

        // Logged in — go to inquiry page with program pre-selected
        window.location.href = '/inquiry?program=' + encodeURIComponent(selectedProgramName);
      });
    });
  });
</script>

