<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'EduLead | Student Admissions Portal' %></title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Custom Stylesheet -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%=
  (path === '/' || path.startsWith('/student/') || path === '/my-inquiry-status' || path === '/inquiry' || path === '/my-documents')
    ? 'light-landing-theme'
    : (admin && !path.startsWith('/student/') && path !== '/my-inquiry-status' && path !== '/inquiry' && path !== '/my-documents' ? 'admin-theme' : '')
%>">

  <!-- Top Navigation Bar -->
  <% if (path === '/' || path.startsWith('/student/') || path === '/my-inquiry-status' || path === '/inquiry' || path === '/my-documents') { %>
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top landing-navbar py-3 border-bottom shadow-sm">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2 fw-bold text-navy" href="/" style="font-family: 'Outfit', sans-serif; font-size: 1.5rem; color: #0F172A;">
          <i class="bi bi-mortarboard-fill text-primary-blue" style="color: #2563EB; font-size: 1.8rem;"></i>
          <span style="letter-spacing: -0.5px;">EduLead</span>
        </a>
        
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarLandingContent" aria-controls="navbarLandingContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarLandingContent">
          <ul class="navbar-nav mx-auto gap-4 mt-2 mt-lg-0">
            <li class="nav-item">
              <a class="nav-link fw-semibold text-slate <%= path === '/' ? 'active' : '' %>" href="<%= path === '/' ? '#home' : '/' %>">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-semibold text-slate" href="<%= path === '/' ? '#programs' : '/#programs' %>">Programs</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-semibold text-slate" href="<%= path === '/' ? '#about' : '/#about' %>">About</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-semibold text-slate" href="<%= path === '/' ? '#contact' : '/#contact' %>">Contact</a>
            </li>
          </ul>
          
          <div class="d-flex align-items-center flex-wrap gap-2 mt-2 mt-lg-0">
            <% if (student) { %>
              <!-- Student Logged In Nav Actions -->
              <a class="nav-link fw-bold text-navy px-2 <%= path === '/my-inquiry-status' ? 'active' : '' %>" href="/my-inquiry-status" style="color: #0F172A; font-family: 'Outfit', sans-serif;">
                <i class="bi bi-clipboard2-check me-1 text-primary-blue" style="color: #2563EB;"></i> My Inquiry
              </a>
              <a class="nav-link fw-bold text-navy px-2 <%= path === '/my-documents' ? 'active' : '' %>" href="/my-documents" style="color: #0F172A; font-family: 'Outfit', sans-serif;">
                <i class="bi bi-folder2-open me-1" style="color: #8B5CF6;"></i> My Documents
              </a>
              <span class="text-muted d-none d-lg-inline">|</span>
              <a class="btn btn-outline-danger px-3 py-2 font-semibold" href="/student/logout" style="border-radius: 8px; font-size: 0.9rem;">
                <i class="bi bi-box-arrow-right"></i> Logout
              </a>
            <% } %>
            
            <span class="text-muted d-none d-lg-inline ms-1">|</span>
            
            <!-- Counsellor Entrance Pathway -->
            <% if (admin) { %>
              <a class="btn btn-outline-primary px-3 py-2 font-semibold d-flex align-items-center gap-1" href="/dashboard" style="border-color: #2563EB; color: #2563EB; border-radius: 8px; font-size: 0.9rem;">
                <i class="bi bi-speedometer2"></i> Dashboard
              </a>
            <% } else { %>
              <a class="btn btn-outline-secondary px-3 py-2 font-semibold d-flex align-items-center gap-1" href="/auth/login" style="border-color: #CBD5E1; color: #475569; border-radius: 8px; font-size: 0.9rem;">
                <i class="bi bi-shield-lock"></i> Counsellor
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  <% } else { %>
    <nav class="navbar navbar-expand-lg admin-navbar">
      <div class="container-fluid px-4">

        <!-- Left: EduLead Brand -->
        <a class="navbar-brand admin-brand" href="/">
          <div class="admin-brand-icon">
            <i class="bi bi-mortarboard-fill"></i>
          </div>
          <div>
            <span class="admin-brand-name">EduLead</span>
            <span class="admin-brand-sub">Admissions Portal</span>
          </div>
        </a>

        <!-- Right: Counsellor Info -->
        <div class="d-flex align-items-center gap-3 ms-auto">
          <% if (admin) { %>
            <div class="admin-user-info d-none d-md-flex align-items-center gap-3">
              <div class="text-end">
                <div class="admin-user-name"><%= admin.username %></div>
                <div class="admin-user-role">Senior Counsellor</div>
              </div>
              <div class="admin-avatar">
                <%= admin.username.substring(0, 1).toUpperCase() %>
              </div>
            </div>
            <a href="/auth/logout" class="admin-logout-btn">
              <i class="bi bi-box-arrow-right"></i>
              <span class="d-none d-md-inline">Sign Out</span>
            </a>
          <% } else { %>
            <a href="/auth/login" class="admin-logout-btn">
              <i class="bi bi-shield-lock"></i>
              <span>Login</span>
            </a>
          <% } %>
        </div>

      </div>
    </nav>
  <% } %>

  <!-- Main Structural Area -->
  <% if (path === '/') { %>
    <main class="flex-grow-1">
      <!-- Render alerts globally within landing layout if present -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="container mt-3">
          <div class="alert alert-success alert-dismissible fade show shadow-sm py-3 px-4 border-0" role="alert" style="background-color: #ECFDF5; color: #047857; border-left: 5px solid #10B981; border-radius: 8px;">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill me-3 fs-5" style="color: #10B981;"></i>
              <div>
                <strong class="d-block mb-1" style="font-family: 'Outfit', sans-serif;">Submission Received!</strong>
                <span><%= success %></span>
              </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="container mt-3">
          <div class="alert alert-danger alert-dismissible fade show shadow-sm py-3 px-4 border-0" role="alert" style="background-color: #FEF2F2; color: #B91C1C; border-left: 5px solid #EF4444; border-radius: 8px;">
            <div class="d-flex align-items-center">
              <i class="bi bi-exclamation-triangle-fill me-3 fs-5" style="color: #EF4444;"></i>
              <div>
                <strong class="d-block mb-1" style="font-family: 'Outfit', sans-serif;">Submission Error</strong>
                <span><%= error %></span>
              </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% } %>
  <% } else if (admin && !path.startsWith('/student/') && path !== '/my-inquiry-status' && path !== '/inquiry' && path !== '/my-documents') { %>
    <div class="sidebar-layout">
      <!-- EduLead Workspace Sidebar -->
      <aside class="sidebar">
        <div class="text-white-50 px-3 py-2 small text-uppercase fw-bold letter-spacing">Management</div>
        <a href="/dashboard" class="sidebar-btn <%= path === '/dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid-1x2-fill"></i>
          <span>Analytics Panel</span>
        </a>
        <a href="/leads" class="sidebar-btn <%= path.startsWith('/leads') && path !== '/leads/add' && !path.includes('/edit') && !path.includes('/details') ? 'active' : '' %>">
          <i class="bi bi-people-fill"></i>
          <span>Student Leads</span>
        </a>
        <a href="/leads/add" class="sidebar-btn <%= path === '/leads/add' ? 'active' : '' %>">
          <i class="bi bi-person-plus-fill"></i>
          <span>Add New Lead</span>
        </a>
        
        <div class="text-white-50 px-3 py-2 mt-4 small text-uppercase fw-bold letter-spacing">Account</div>
        <a href="/auth/logout" class="sidebar-btn text-danger">
          <i class="bi bi-box-arrow-left"></i>
          <span>Sign Out</span>
        </a>
      </aside>

      <!-- Main EduLead Work Environment -->
      <main class="main-content">
        <!-- Render alerts globally within workspace layout if present -->
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-custom alert-success-custom alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-custom alert-danger-custom alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
  <% } else { %>
    <!-- Public/Student/Unauthenticated Container -->
    <main class="flex-grow-1">
      <div class="container my-4">
        <!-- Render alerts globally for public layouts -->
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-custom alert-success-custom alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-custom alert-danger-custom alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
  <% } %>
