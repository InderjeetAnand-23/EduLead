<%- path === '/' ? '</main>' : (admin ? '</main></div>' : '</div></main>') %>

  <!-- Page Footer -->
  <footer class="text-center text-lg-start mt-auto">
    <div class="container text-center py-3">
      <div class="row align-items-center">
        <div class="col-md-6 text-md-start mb-2 mb-md-0">
          <span>&copy; 2026 <strong class="text-info">EduLead</strong>. All Rights Reserved.</span>
        </div>
        <div class="col-md-6 text-md-end">
          <span class="me-3"><i class="bi bi-shield-lock-fill me-1"></i>Secure Admin Workspace</span>
          <span>Version 1.0.0</span>
        </div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap 5 JavaScript Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

  <!-- Global Searchable Country Dropdown Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.country-select-container').forEach(initCountryDropdown);
    });

    function initCountryDropdown(container) {
      const input = container.querySelector('.country-search-input');
      const list = container.querySelector('.country-dropdown-list');
      const toggleBtn = container.querySelector('.dropdown-toggle-btn');
      const noResults = container.querySelector('.country-no-results');

      const countries = [
        "Australia", "Austria", "Bahrain", "Bangladesh", "Belgium", "Brazil", 
        "Canada", "China", "Denmark", "France", "Germany", "Ghana", "India", 
        "Indonesia", "Ireland", "Italy", "Japan", "Kazakhstan", "Kenya", 
        "Kuwait", "Malaysia", "Mexico", "Nepal", "Netherlands", "New Zealand", 
        "Nigeria", "Norway", "Oman", "Pakistan", "Philippines", "Qatar", 
        "Russia", "Saudi Arabia", "Singapore", "South Africa", "South Korea", 
        "Spain", "Sri Lanka", "Sweden", "Switzerland", "Thailand", "United Arab Emirates", 
        "United Kingdom", "United States", "Vietnam"
      ];

      // Populate list
      countries.forEach(country => {
        const item = document.createElement('button');
        item.type = 'button';
        item.className = 'dropdown-item text-white border-0 py-2 px-3 rounded w-100 text-start bg-transparent country-item';
        item.style.fontSize = '0.9rem';
        item.textContent = country;

        item.addEventListener('click', () => {
          input.value = country;
          input.dispatchEvent(new Event('change'));
          hideList();
        });
        list.appendChild(item);
      });

      const items = list.querySelectorAll('.country-item');

      function filterCountries() {
        const filter = input.value.toLowerCase().trim();
        let hasMatches = false;

        items.forEach(item => {
          const text = item.textContent.toLowerCase();
          if (text.includes(filter)) {
            item.style.display = 'block';
            hasMatches = true;
          } else {
            item.style.display = 'none';
          }
        });

        noResults.style.display = hasMatches ? 'none' : 'block';
      }

      function showList() {
        list.style.display = 'block';
        filterCountries();
      }

      function hideList() {
        setTimeout(() => {
          list.style.display = 'none';
        }, 150);
      }

      input.addEventListener('focus', showList);
      input.addEventListener('input', showList);

      document.addEventListener('click', (e) => {
        if (!container.contains(e.target)) {
          list.style.display = 'none';
        }
      });

      if (toggleBtn) {
        toggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (list.style.display === 'block') {
            list.style.display = 'none';
          } else {
            input.focus();
          }
        });
      }
    }
  </script>

</body>
</html>
