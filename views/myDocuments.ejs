<%- include('partials/header') %>

<style>
  .doc-card {
    background: #FFFFFF;
    border: 1.5px solid #E2E8F0;
    border-radius: 16px;
    padding: 24px;
    transition: all 0.2s ease;
    height: 100%;
  }
  .doc-card:hover {
    border-color: rgba(37, 99, 235, 0.2);
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.07);
    transform: translateY(-2px);
  }
  .doc-type-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem;
    flex-shrink: 0;
  }
  .badge-uploaded  { background: rgba(37,99,235,0.1);  color: #2563EB; border: 1px solid rgba(37,99,235,0.2); border-radius: 20px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; }
  .badge-verified  { background: rgba(16,185,129,0.1); color: #059669; border: 1px solid rgba(16,185,129,0.2); border-radius: 20px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; }
  .badge-rejected  { background: rgba(239,68,68,0.1);  color: #DC2626; border: 1px solid rgba(239,68,68,0.2);  border-radius: 20px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; }
  .badge-pending   { background: rgba(100,116,139,0.08); color: #64748B; border: 1px solid #E2E8F0; border-radius: 20px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; }

  .upload-zone {
    border: 2px dashed #CBD5E1;
    border-radius: 10px;
    padding: 14px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #F8FAFC;
  }
  .upload-zone:hover { border-color: #2563EB; background: rgba(37,99,235,0.03); }

  .file-input-hidden { display: none; }

  .doc-file-item {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 10px 14px;
    margin-top: 10px;
  }

  .submit-upload-btn {
    background: linear-gradient(135deg, #2563EB, #1D4ED8);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 9px 20px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    margin-top: 10px;
  }
  .submit-upload-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(37,99,235,0.35); }

  .delete-btn {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.2);
    color: #EF4444;
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .delete-btn:hover { background: #EF4444; color: #fff; }

  .view-btn {
    background: rgba(37,99,235,0.08);
    border: 1px solid rgba(37,99,235,0.2);
    color: #2563EB;
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .view-btn:hover { background: #2563EB; color: #fff; }
</style>

<section class="min-vh-100 py-5" style="background: linear-gradient(145deg, #F0F4FF 0%, #F8FAFC 60%, #F0FDF9 100%); padding-top: 90px !important;">
  <div class="container">

    <!-- Page Header -->
    <div class="mb-5">
      <div class="d-flex align-items-center gap-3 mb-2">
        <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #2563EB, #14B8A6); display: flex; align-items: center; justify-content: center;">
          <i class="bi bi-folder2-open" style="color: #fff; font-size: 1.2rem;"></i>
        </div>
        <div>
          <h1 style="font-family: 'Outfit', sans-serif; font-size: 1.6rem; font-weight: 800; color: #0F172A; margin: 0; letter-spacing: -0.3px;">My Documents</h1>
          <p style="color: #64748B; margin: 0; font-size: 0.9rem;">Upload your admission documents. Each file must be PDF, JPG, or PNG (max 5MB).</p>
        </div>
      </div>
    </div>

    <!-- Alerts -->
    <% 
      const urlParams = new URLSearchParams(typeof query !== 'undefined' ? query : '');
      const flashError = typeof error !== 'undefined' ? error : null;
      const flashSuccess = typeof success !== 'undefined' ? success : null;
    %>
    <% if (flashError) { %>
      <div class="d-flex align-items-center gap-2 mb-4 px-4 py-3"
           style="background:#FEF2F2; border-radius:12px; border-left:4px solid #EF4444;">
        <i class="bi bi-exclamation-circle-fill" style="color:#EF4444;"></i>
        <span style="color:#B91C1C; font-size:0.875rem;"><%= flashError %></span>
      </div>
    <% } %>
    <% if (flashSuccess) { %>
      <div class="d-flex align-items-center gap-2 mb-4 px-4 py-3"
           style="background:#ECFDF5; border-radius:12px; border-left:4px solid #10B981;">
        <i class="bi bi-check-circle-fill" style="color:#10B981;"></i>
        <span style="color:#047857; font-size:0.875rem;"><%= flashSuccess %></span>
      </div>
    <% } %>

    <!-- Document Cards Grid -->
    <div class="row g-4">
      <% 
        const typeConfig = {
          passport:     { label: 'Passport', icon: 'bi-passport', color: '#2563EB', bg: 'rgba(37,99,235,0.08)' },
          marksheet:    { label: 'Marksheet / Transcript', icon: 'bi-file-earmark-text', color: '#8B5CF6', bg: 'rgba(139,92,246,0.08)' },
          id_proof:     { label: 'ID Proof', icon: 'bi-person-badge', color: '#14B8A6', bg: 'rgba(20,184,166,0.08)' },
          offer_letter: { label: 'Offer Letter', icon: 'bi-envelope-paper', color: '#F59E0B', bg: 'rgba(245,158,11,0.08)' },
          other:        { label: 'Other Document', icon: 'bi-paperclip', color: '#64748B', bg: 'rgba(100,116,139,0.08)' }
        };
      %>

      <% docTypes.forEach(type => { %>
        <% const cfg = typeConfig[type]; %>
        <% const docs = docsByType[type] || []; %>
        <% const latestDoc = docs[0] || null; %>

        <div class="col-md-6 col-xl-4">
          <div class="doc-card">

            <!-- Card Header -->
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div class="d-flex align-items-center gap-3">
                <div class="doc-type-icon" style="background: <%= cfg.bg %>; color: <%= cfg.color %>;">
                  <i class="bi <%= cfg.icon %>"></i>
                </div>
                <div>
                  <div style="font-family:'Outfit',sans-serif; font-weight:700; color:#0F172A; font-size:0.95rem;"><%= cfg.label %></div>
                  <% if (!latestDoc) { %>
                    <span class="badge-pending">Not Uploaded</span>
                  <% } else if (latestDoc.status === 'uploaded') { %>
                    <span class="badge-uploaded"><i class="bi bi-cloud-check me-1"></i>Uploaded</span>
                  <% } else if (latestDoc.status === 'verified') { %>
                    <span class="badge-verified"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
                  <% } else if (latestDoc.status === 'rejected') { %>
                    <span class="badge-rejected"><i class="bi bi-x-circle-fill me-1"></i>Rejected</span>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Uploaded File Info -->
            <% if (latestDoc) { %>
              <div class="doc-file-item">
                <div class="d-flex align-items-center justify-content-between">
                  <div style="overflow: hidden;">
                    <div style="font-weight:600; color:#334155; font-size:0.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                      <i class="bi bi-file-earmark me-1" style="color:#64748B;"></i><%= latestDoc.originalName %>
                    </div>
                    <div style="color:#94A3B8; font-size:0.75rem; margin-top:2px;">
                      Uploaded <%= new Date(latestDoc.uploadedAt).toLocaleDateString('en-US', { day:'numeric', month:'short', year:'numeric' }) %>
                    </div>
                  </div>
                  <div class="d-flex gap-2 ms-2 flex-shrink-0">
                    <a href="/<%= latestDoc.filePath %>" target="_blank" class="view-btn">
                      <i class="bi bi-eye"></i>
                    </a>
                    <% if (latestDoc.status !== 'verified') { %>
                      <form action="/my-documents/<%= latestDoc._id %>/delete" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete this document?');">
                        <button type="submit" class="delete-btn" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </div>

                <!-- Rejection Note -->
                <% if (latestDoc.status === 'rejected' && latestDoc.adminNote) { %>
                  <div class="mt-2 px-3 py-2" style="background:rgba(239,68,68,0.06); border-radius:8px; border-left:3px solid #EF4444;">
                    <div style="font-size:0.78rem; color:#B91C1C; font-weight:600;">Rejection Reason:</div>
                    <div style="font-size:0.8rem; color:#7F1D1D;"><%= latestDoc.adminNote %></div>
                  </div>
                <% } %>

                <!-- Verified Note -->
                <% if (latestDoc.status === 'verified') { %>
                  <div class="mt-2 px-3 py-2" style="background:rgba(16,185,129,0.06); border-radius:8px; border-left:3px solid #10B981;">
                    <div style="font-size:0.78rem; color:#047857; font-weight:600;">
                      <i class="bi bi-patch-check-fill me-1"></i>Verified by counsellor
                      <% if (latestDoc.reviewedAt) { %>
                        on <%= new Date(latestDoc.reviewedAt).toLocaleDateString('en-US', { day:'numeric', month:'short', year:'numeric' }) %>
                      <% } %>
                    </div>
                  </div>
                <% } %>
              </div>
            <% } %>

            <!-- Upload Form (show if not uploaded yet OR if rejected — re-upload) -->
            <% if (!latestDoc || latestDoc.status === 'rejected') { %>
              <form action="/my-documents/upload" method="POST" enctype="multipart/form-data" class="mt-3">
                <input type="hidden" name="documentType" value="<%= type %>">
                <div class="upload-zone" onclick="document.getElementById('file_<%= type %>').click()">
                  <i class="bi bi-cloud-arrow-up" style="font-size:1.5rem; color:#94A3B8; display:block;"></i>
                  <div style="color:#64748B; font-size:0.82rem; margin-top:4px;">Click to choose file</div>
                  <div style="color:#94A3B8; font-size:0.75rem;">PDF, JPG, PNG — max 5MB</div>
                </div>
                <input type="file" id="file_<%= type %>" name="documentFile" class="file-input-hidden"
                       accept=".pdf,.jpg,.jpeg,.png"
                       onchange="showFileName(this, '<%= type %>')">
                <div id="preview_<%= type %>" style="color:#2563EB; font-size:0.82rem; margin-top:6px; display:none;"></div>
                <button type="submit" class="submit-upload-btn">
                  <i class="bi bi-cloud-upload me-1"></i>
                  <%= latestDoc ? 'Re-upload Document' : 'Upload Document' %>
                </button>
              </form>
            <% } %>

            <!-- All versions (if multiple uploads) -->
            <% if (docs.length > 1) { %>
              <div class="mt-3">
                <div style="font-size:0.75rem; color:#94A3B8; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">Previous uploads</div>
                <% docs.slice(1).forEach(d => { %>
                  <div style="font-size:0.78rem; color:#64748B; padding:4px 0; border-top:1px solid #F1F5F9;">
                    <i class="bi bi-file-earmark me-1"></i><%= d.originalName %>
                    — <span style="color:<%= d.status==='verified'?'#059669':d.status==='rejected'?'#DC2626':'#2563EB' %>"><%= d.status %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>

          </div>
        </div>
      <% }) %>
    </div>

    <!-- Back link -->
    <div class="text-center mt-5">
      <a href="/my-inquiry-status" class="text-decoration-none" style="color:#94A3B8; font-size:0.875rem;">
        <i class="bi bi-arrow-left me-1"></i> Back to My Inquiry Status
      </a>
    </div>

  </div>
</section>

<script>
function showFileName(input, type) {
  const preview = document.getElementById('preview_' + type);
  if (input.files && input.files[0]) {
    preview.textContent = '📎 ' + input.files[0].name;
    preview.style.display = 'block';
  }
}
</script>

<%- include('partials/footer') %>
