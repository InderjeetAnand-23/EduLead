<%- include('partials/header') %>

<%
// Preformat followUpDate to YYYY-MM-DD for the HTML5 date input element
let formattedDate = '';
if (lead.followUpDate) {
  const d = new Date(lead.followUpDate);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  formattedDate = `${year}-${month}-${day}`;
}
%>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb bg-transparent p-0 mb-2">
      <li class="breadcrumb-item"><a href="/dashboard" class="text-cyan text-decoration-none">Dashboard</a></li>
      <li class="breadcrumb-item"><a href="/leads" class="text-cyan text-decoration-none">Leads</a></li>
      <li class="breadcrumb-item"><a href="/leads/<%= lead._id %>" class="text-cyan text-decoration-none"><%= lead.fullName %></a></li>
      <li class="breadcrumb-item active text-white" aria-current="page">Edit Lead</li>
    </ol>
  </nav>
  <h2 class="fw-bold mb-1"><i class="bi bi-pencil-square me-2 text-warning"></i>Edit Student Lead</h2>
  <p class="text-muted mb-0">Modify academic context, follow-up timelines, or status assignments for <%= lead.fullName %>.</p>
</div>

<% if (error) { %>
  <div class="alert alert-custom alert-danger-custom alert-dismissible fade show mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="card glass-card p-4 border-0 mb-5 shadow-lg">
  
  <!-- Use method-override to turn POST into PUT -->
  <form action="/leads/<%= lead._id %>?_method=PUT" method="POST">
    
    <!-- 1. Profile details -->
    <h5 class="fw-bold mb-3 text-cyan border-bottom border-secondary pb-2"><i class="bi bi-person-bounding-box me-2"></i>Personal Profile Details</h5>
    
    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label for="fullName">Student Full Name <span class="text-danger">*</span></label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-person"></i></span>
          <input type="text" class="form-control bg-dark text-white border-secondary" id="fullName" name="fullName" value="<%= lead.fullName %>" required>
        </div>
      </div>
      <div class="col-md-6">
        <label for="email">Email Address <span class="text-danger">*</span></label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-envelope"></i></span>
          <input type="email" class="form-control bg-dark text-white border-secondary" id="email" name="email" value="<%= lead.email %>" required>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label for="phone">Phone / Mobile Number <span class="text-danger">*</span></label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-telephone"></i></span>
          <input type="tel" class="form-control bg-dark text-white border-secondary" id="phone" name="phone" value="<%= lead.phone %>" required>
        </div>
      </div>
      <div class="col-md-6">
        <label for="country">Country of Residence <span class="text-danger">*</span></label>
        <div class="country-select-container">
          <div class="input-group">
            <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-geo-alt"></i></span>
            <input type="text" 
                   class="form-control bg-dark text-white border-secondary country-search-input" 
                   id="country" 
                   name="country" 
                   value="<%= lead.country %>" 
                   placeholder="Search or select country..." 
                   autocomplete="off" 
                   required>
            <button class="btn btn-outline-secondary border-secondary bg-dark text-muted dropdown-toggle-btn" type="button" tabindex="-1">
              <i class="bi bi-chevron-down small"></i>
            </button>
          </div>
          <div class="country-dropdown-list shadow-lg p-2">
            <div class="country-no-results text-muted p-2 small" style="display: none;">No matching countries found</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Academic Info -->
    <h5 class="fw-bold mb-3 text-cyan border-bottom border-secondary pb-2 mt-4"><i class="bi bi-mortarboard me-2"></i>Academic & Admissions Context</h5>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label for="courseInterested">Course of Interest <span class="text-danger">*</span></label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-book"></i></span>
          <select class="form-select bg-dark text-white border-secondary" id="courseInterested" name="courseInterested" required>
            <option value="" disabled>Select a program</option>
            <option value="Computer Science & Engineering" <%= lead.courseInterested === 'Computer Science & Engineering' ? 'selected' : '' %>>Computer Science & Engineering</option>
            <option value="Data Science & AI" <%= lead.courseInterested === 'Data Science & AI' ? 'selected' : '' %>>Data Science & AI</option>
            <option value="Business Administration" <%= lead.courseInterested === 'Business Administration' ? 'selected' : '' %>>Business Administration</option>
            <option value="Biotechnology" <%= lead.courseInterested === 'Biotechnology' ? 'selected' : '' %>>Biotechnology</option>
            <option value="Mechanical Engineering" <%= lead.courseInterested === 'Mechanical Engineering' ? 'selected' : '' %>>Mechanical Engineering</option>
            <option value="Information Technology" <%= lead.courseInterested === 'Information Technology' ? 'selected' : '' %>>Information Technology</option>
          </select>
        </div>
      </div>
      <div class="col-md-6">
        <label for="qualification">Highest Educational Qualification</label>
        <input type="text" class="form-control bg-dark text-white border-secondary" id="qualification" name="qualification" value="<%= lead.qualification || '' %>" placeholder="e.g. B.Sc, High School">
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label for="budget">Annual Tuition Budget (USD)</label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-currency-dollar"></i></span>
          <input type="text" class="form-control bg-dark text-white border-secondary" id="budget" name="budget" value="<%= lead.budget || '' %>" placeholder="e.g. $10,000">
        </div>
      </div>
      <div class="col-md-6">
        <label for="leadSource">Lead Source</label>
        <select class="form-select bg-dark text-white border-secondary" id="leadSource" name="leadSource">
          <option value="Website Inquiry Form" <%= lead.leadSource === 'Website Inquiry Form' ? 'selected' : '' %>>Website Inquiry Form</option>
          <option value="Manual Entry" <%= lead.leadSource === 'Manual Entry' ? 'selected' : '' %>>Manual Entry</option>
          <option value="Direct Walk-in" <%= lead.leadSource === 'Direct Walk-in' ? 'selected' : '' %>>Direct Walk-in</option>
          <option value="Phone Inquiry" <%= lead.leadSource === 'Phone Inquiry' ? 'selected' : '' %>>Phone Inquiry</option>
          <option value="Educational Fair" <%= lead.leadSource === 'Educational Fair' ? 'selected' : '' %>>Educational Fair</option>
          <option value="Email Newsletter" <%= lead.leadSource === 'Email Newsletter' ? 'selected' : '' %>>Email Newsletter</option>
          <option value="Social Media Campaign" <%= lead.leadSource === 'Social Media Campaign' ? 'selected' : '' %>>Social Media Campaign</option>
          <option value="Agency Referral" <%= lead.leadSource === 'Agency Referral' ? 'selected' : '' %>>Agency Referral</option>
        </select>
      </div>
    </div>

    <!-- 3. Workflow tracking -->
    <h5 class="fw-bold mb-3 text-cyan border-bottom border-secondary pb-2 mt-4"><i class="bi bi-alarm me-2"></i>Workspace Actions</h5>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label for="status">Lead Status Option</label>
        <select class="form-select bg-dark text-white border-secondary" id="status" name="status">
          <option value="New Inquiry" <%= lead.status === 'New Inquiry' ? 'selected' : '' %>>New Inquiry</option>
          <option value="Contacted" <%= lead.status === 'Contacted' ? 'selected' : '' %>>Contacted</option>
          <option value="Interested" <%= lead.status === 'Interested' ? 'selected' : '' %>>Interested</option>
          <option value="Documents Pending" <%= lead.status === 'Documents Pending' ? 'selected' : '' %>>Documents Pending</option>
          <option value="Documents Verified" <%= lead.status === 'Documents Verified' ? 'selected' : '' %>>Documents Verified</option>
          <option value="Application Submitted" <%= lead.status === 'Application Submitted' ? 'selected' : '' %>>Application Submitted</option>
          <option value="Offer Letter Issued" <%= lead.status === 'Offer Letter Issued' ? 'selected' : '' %>>Offer Letter Issued</option>
          <option value="Fee Pending" <%= lead.status === 'Fee Pending' ? 'selected' : '' %>>Fee Pending</option>
          <option value="Admitted" <%= lead.status === 'Admitted' ? 'selected' : '' %>>Admitted</option>
          <option value="Rejected" <%= lead.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="Not Interested" <%= lead.status === 'Not Interested' ? 'selected' : '' %>>Not Interested</option>
        </select>
      </div>
      <div class="col-md-6">
        <label for="followUpDate">Modify Follow-up Date</label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-calendar-event"></i></span>
          <input type="date" class="form-control bg-dark text-white border-secondary" id="followUpDate" name="followUpDate" value="<%= formattedDate %>">
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label for="notes">Counselor Remarks & Counseling Notes</label>
      <textarea class="form-control bg-dark text-white border-secondary" id="notes" name="notes" rows="5" placeholder="Document the student's background, outstanding transcripts, next follow-up agenda..."><%= lead.notes %></textarea>
    </div>

    <!-- Actions -->
    <div class="d-flex justify-content-between gap-3 border-top border-secondary pt-3 flex-wrap">
      <!-- Delete in Edit form -->
      <button type="button" class="btn btn-outline-danger px-4" onclick="if(confirm('Are you sure you want to permanently delete lead <%= lead.fullName %>?')){ document.getElementById('deleteForm').submit(); }">
        <i class="bi bi-trash-fill me-1"></i>Delete Record
      </button>

      <div class="d-flex gap-3">
        <a href="/leads/<%= lead._id %>" class="btn btn-outline-secondary text-white border-secondary px-4">Cancel</a>
        <button type="submit" class="btn btn-gradient px-4"><i class="bi bi-save me-1"></i>Save Changes</button>
      </div>
    </div>

  </form>

  <!-- Separate Hidden form for Delete -->
  <form id="deleteForm" action="/leads/<%= lead._id %>?_method=DELETE" method="POST" class="d-none"></form>
</div>

<%- include('partials/footer') %>
